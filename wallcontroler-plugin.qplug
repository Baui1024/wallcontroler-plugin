-- Information block for the plugin
PluginInfo = {
  Name = "Node Core 4",
  Version = "1.0",
  BuildVersion = "1.0.0.102",
  Id = "ecb3592b-01c9-4f20-9d34-9f98002e56fc",
  Author = "Touch Forge",
  Description = "A very basic plugin"  
